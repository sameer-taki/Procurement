# .env.example — DOCUMENTATION ONLY. Real values go in Portainer env vars, never in git.
# Local dev: copy to .env and fill. Generate secrets:
#   docker run --rm python:3.12-slim python -c "import secrets; print(secrets.token_urlsafe(48))"

# --- required (skill standard) ---
APP_HOST=procurement.gml.com.fj
DB_PASSWORD=                 # strong random; PERMANENT for the life of the pgdata volume
SECRET_KEY=                  # 32+ chars; app refuses placeholder
ADMIN_USERNAME=admin
ADMIN_PASSWORD=              # change on first login
APP_ENV=production

# --- app behaviour (optional; sensible defaults) ---
# USE_FAKE_ADAPTERS=        # unset = auto (demo data only for unconfigured sources)
# STOCK_REFRESH_SECONDS=1800
# SEED_DEMO_ON_EMPTY=true   # set false to start with an empty catalog
# USAGE_IMPORT_SECONDS=86400  # scheduled BC usage import for paper planning (daily)

# --- Business Central (Phase 1+) : on-prem, reachable from the Docker host ---
# See INTEGRATIONS.md. Demo data until BASE_URL + USERNAME + PASSWORD are all set.
# Every entity set / field name the adapter assumes is overridable (BC_*_ENTITY,
# BC_*_FIELD, BC_PAPER_SKU_REGEX, CROSSWALK_MODE) — see INTEGRATIONS.md §2 for
# the full table; the defaults are standard BC V4 names.
# Verified GML tenant (bc-test): http, instance BC140, NTLM domain accounts.
BC_BASE_URL=http://172.16.1.10:7048/BC140/ODataV4
BC_COMPANY=Golden Manufacturers Pte Ltd
BC_USERNAME=                # GML\<service-account>  (read-only recommended for now)
BC_PASSWORD=
BC_AUTH=ntlm               # ntlm (GML domain accounts) | basic (NavUserPassword)
# BC_VERIFY_TLS=true        # irrelevant over http; set false only for a self-signed https cert
# GML item numbers ARE the grade (WTL175, BX186) — one item per grade, no deckle
# suffix — so a grade-only pattern is required or live paper items aren't recognised:
# BC_PAPER_SKU_REGEX=^([A-Z]{2,4}\d{3})$
# BC_USAGE_ENTRY_TYPES=Negative Adjmt.,Consumption   # Kiwiplan usage posts as Negative Adjmt.
# BC_ITEMS_ENTITY=Items     # OData item-master entity set (publish Page 31 as 'Items')
# BC_CUSTOMERS_ENTITY=Customers  # customer master (publish Page 22 as 'Customers')
# BC_USAGE_ENTITY=ItemLedgerEntries  # usage export (published on GML's BC140 already)
# BC_USAGE_ENTRY_TYPES=Negative Adjmt.,Consumption  # Kiwiplan usage posts as Negative Adjmt.
# Live PO writes on BC14: External_Document_No isn't exposed on the Purchase Order
# page — point the idempotency tag at a field that IS (confirm it's free first).
# BC_PO_EXTREF_FIELD=Vendor_Order_No
# Live receipt writes: set the correlation field to make receipt posting exactly-once
# (blank = best-effort, double-post risk on a lost response — run receipts read-only).
# Your_Reference carries through posting and is usually free; confirm it isn't holding a
# real buyer reference on your tenant before enabling. See INTEGRATIONS.md.
# BC_RECEIPT_CORRELATION_FIELD=Your_Reference

# --- Kiwiplan (Phase 1 read / Phase 4 inject) ---
# Live needs BOTH the DSN and the SQL (returns location/on_hand/allocated/on_order, :item_ref).
KIWIPLAN_DSN=               # KDW / SQL ODBC connection string
# KIWIPLAN_STOCK_SQL=SELECT warehouse AS location, qoh AS on_hand, alloc AS allocated, onord AS on_order FROM kdw_stock WHERE material_code = :item_ref

# --- Accura (Phase 1 read) ---
ACCURA_DSN=                 # ODBC DSN / connection string
# ACCURA_STOCK_SQL=SELECT location, on_hand, allocated, on_order FROM stock WHERE code = :item_ref

# --- M365 Graph mailer (Phase 3) : existing "Golden Apps Mailer" registration ---
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER=no-reply@golden.com.fj

# --- Azure SQL warehouse (Phase 5 analytics push) ---
# Demo/unconfigured until set: the warehouse writer no-ops ('skipped:not-configured').
# See INTEGRATIONS.md. WAREHOUSE_DSN is accepted as an alias of AZURE_SQL_DSN.
# AZURE_SQL_DSN=            # full pyodbc connection string for the Azure SQL warehouse

# --- Entra ID SSO (Phase 1) ---
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=https://procurement.gml.com.fj/auth/callback

# --- optional backup retention ---
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6
