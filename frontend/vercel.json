{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://mcp.golden.com.fj/api/:path*" },
    { "source": "/auth/:path*", "destination": "https://mcp.golden.com.fj/auth/:path*" },
    { "source": "/health", "destination": "https://mcp.golden.com.fj/health" },
    { "source": "/((?!api/|auth/|health).*)", "destination": "/index.html" }
  ]
}
